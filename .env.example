# Скопируйте в .env.local и заполните (не коммитьте .env.local в git).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Для СЕТЕВОГО сервера (production): ключи вшиваются при npm run build.
# Если сборка без .env — скопируйте public/cloud-config.example.json → public/cloud-config.json
# и заполните теми же url/anonKey (файл подгрузится в браузере автоматически).

# Cloudflare API token (альтернатива wrangler login, см. infra/CLOUDFLARE-WORKER-R2.ru.md)
# CLOUDFLARE_API_TOKEN=

# Графика / 3D — Cloudflare Worker + R2 (см. infra/CLOUDFLARE-WORKER-R2.ru.md)
# VITE_ASSET_CDN_URL=https://starfall-assets-cdn.xxx.workers.dev/cdn/

# Бои WebSocket — Render (бесплатно) или Oracle (мощнее), см. infra/deploy-render.ru.md
# VITE_EDGE_SERVER_URL=https://starfall-edge.onrender.com

# Диспетчер команд — Render (см. infra/deploy-party-render.ru.md)
# VITE_GAME_SERVER_URL=https://starfall-party.onrender.com
# VITE_GAME_SERVER_WS_URL=wss://starfall-party.onrender.com/ws
