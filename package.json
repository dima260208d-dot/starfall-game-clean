    "wouter": "^3.3.5",
    "zod": "^3.24.2"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@types/three": "^0.184.0",
    "cannon-es": "^0.20.0",
    "lil-gui": "^0.21.0",
    "three": "^0.184.0",
    "three.terrain.js": "^2.0.0"
