{
  "name": "clash-arena",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fix-encoding": "node scripts/fix-encoding.mjs",
    "dev": "node scripts/fix-encoding.mjs && vite --config vite.config.ts --host 0.0.0.0",
    "build": "node scripts/fix-encoding.mjs && vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pins:manifest": "node scripts/build-game-pin-manifest.mjs",
    "pins:delete-non-character": "node scripts/delete-non-character-pins.mjs",
    "pins:install-asset": "node scripts/install-pin-raw.mjs",
    "pins:install-raw": "node scripts/install-pin-raw.mjs",
    "pins:generate-one": "node scripts/generate-game-pin-openai.mjs",
    "pins:regenerate-all": "node scripts/regenerate-all-game-pins.mjs",
    "pins:remove-bg": "node scripts/remove-pin-backgrounds.mjs",
    "ui-icons:process": "node scripts/process-ui-icons.mjs",
    "pins:optimize": "node scripts/optimize-pin-pngs.mjs",
    "profile-icons:generate": "node scripts/generate-profile-icons.mjs",
    "ranked-ui:install": "node scripts/generate-ranked-assets.mjs",
    "ranked-league-icons:install": "node scripts/install-ranked-league-icons.mjs",
    "ranked-league-icons:svg": "node scripts/generate-ranked-league-icons.mjs",
    "profile-icons:manifest": "node scripts/build-gen-icon-manifest.mjs",
    "comics:manifest": "node scripts/fix-encoding.mjs && node scripts/export-brawler-comics-manifest.mjs",
    "profile-icons:sync": "node scripts/sync-gen-profile-icons.mjs",
    "pro-pass:generate-all": "node scripts/generate-all-pro-pass.mjs all",
    "pro-pass:install": "node scripts/install-pro-pass-asset.mjs",
    "i18n:ru": "node scripts/write-ru-messages.mjs",
    "i18n:en": "node scripts/write-en-messages.mjs",
    "i18n:seed": "node scripts/seed-locales-from-en.mjs",
    "i18n:translate": "node scripts/translate-from-en.mjs",
    "i18n:translate:all": "node scripts/translate-from-en.mjs",
    "i18n:fill-all": "node scripts/translate-from-en.mjs",
    "i18n:persist": "node scripts/i18n-persist-locale.mjs",
    "i18n:persist:parallel": "node scripts/i18n-persist-parallel.mjs",
    "i18n:sync": "node scripts/i18n-sync-new-keys.mjs",
    "i18n:entity": "node scripts/gen-entity-i18n.mjs",
